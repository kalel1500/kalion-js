{
    "name": "@kalel1500/kalion-js",
    "version": "0.16.0-beta.0",
    "description": "Utilidades de typescript para Laravel",
    "type": "module",
    "main": "dist/kalion-js.js",
    "types": "dist/kalion-js.d.ts",
    "exports": {
        ".": {
            "types": "./dist/kalion-js.d.ts",
            "import": "./dist/kalion-js.js"
        },
        "./vite-plugin": {
            "types": "./dist/plugins/vite-plugin.d.ts",
            "import": "./dist/plugins/vite-plugin.js"
        },
        "./css/*.css": "./dist/css/*.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build:app": "vite build",
        "build:styles": "cross-env BUILD_TARGET=styles vite build",
        "build:pluginV": "cross-env BUILD_TARGET=pluginV vite build",
        "build:plugins": "npm run build:pluginV",
        "build:library": "npm run build:app && npm run build:styles",
        "build": "tsc && npm run build:library && npm run build:plugins"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kalel1500/kalion-js.git"
    },
    "keywords": [
        "laravel",
        "ts",
        "utilities",
        "utils",
        "typescript"
    ],
    "author": "kalel1500",
    "license": "GPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/kalel1500/kalion-js/issues"
    },
    "homepage": "https://github.com/kalel1500/kalion-js#readme",
    "devDependencies": {
        "@types/bootstrap": "^5.2.10",
        "@types/node": "^25.9.1",
        "autoprefixer": "^10.5.0",
        "cross-env": "^10.1.0",
        "postcss-nested": "^7.0.2",
        "tailwindcss": "^4.0.9",
        "typescript": "^6.0.3",
        "vite": "^8.0.5",
        "vite-plugin-dts": "^5.0.1"
    },
    "dependencies": {
        "@types/luxon": "^3.4.2",
        "@types/tabulator-tables": "^6.2.4",
        "flowbite": "^4.0.2",
        "laravel-echo": "^2.0.0",
        "luxon": "^3.5.0",
        "pusher-js": "^8.4.0",
        "slim-select": "^3.4.3",
        "sweetalert2": "^11.11.2",
        "tabulator-tables": "^6.3.1",
        "ziggy-js": "^2.5.1"
    }
}
